{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Generated schema for Musics",
  "type": "object",
  "properties": {
    "romanji": {
      "type": "string"
    },
    "hiragana": {
      "type": "string"
    },
    "portuguese": {
      "type": "string"
    },
    "english": {
      "type": "string"
    },
    "duration": {
      "type": "number"
    },
    "youtubeVideoClipId": {
      "type": "string"
    },
    "youtubeMusicId": {
      "type": "string"
    },
    "spotifyId": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "releaseDate": {
      "type": "string",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/[0-9]{4}$"
    }
  },
  "required": [
    "romanji",
    "hiragana",
    "portuguese",
    "english",
    "duration",
    "releaseDate"
  ]
}
